score++;
result+=`<p class='correct'>✔ ${q.q}</p>`;
}else{
result+=`<p class='wrong'>✘ ${q.q}<br>Your Answer: ${q.options[val]}<br>Correct Answer: ${q.options[q.answer]}</p>`;
}
}else{
result+=`<p class='wrong'>✘ ${q.q}<br>Not Attempted<br>Correct Answer: ${q.options[q.answer]}</p>`;
}
});

